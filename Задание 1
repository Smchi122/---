start, end = map(int, input().split())

if start >= end:
    print("Ошибка: начало диапазона должно быть меньше конца.")
else:
    fib1, fib2 = 0, 1
    fibonacci_in_range = []

    while fib1 <= end:
        if fib1 >= start:
            fibonacci_in_range.append(fib1)
        fib1, fib2 = fib2, fib1 + fib2

    if fibonacci_in_range:
        print(' '.join(map(str, fibonacci_in_range)))
    else:
        print("В заданном диапазоне нет чисел Фибоначчи")
